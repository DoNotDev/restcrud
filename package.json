{
  "name": "@donotdev/restcrud",
  "version": "0.1.44",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "REST CRUD provider for DoNotDev — plain JSON-over-HTTP adapter for self-hosted backends",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./server/express": {
      "types": "./src/server/express.ts",
      "import": "./src/server/express.ts",
      "default": "./src/server/express.ts"
    },
    "./server/hono": {
      "types": "./src/server/hono.ts",
      "import": "./src/server/hono.ts",
      "default": "./src/server/hono.ts"
    },
    "./server/fastify": {
      "types": "./src/server/fastify.ts",
      "import": "./src/server/fastify.ts",
      "default": "./src/server/fastify.ts"
    },
    "./server/next": {
      "types": "./src/server/next.ts",
      "import": "./src/server/next.ts",
      "default": "./src/server/next.ts"
    }
  },
  "scripts": {
    "dev": "tsc --noEmit --watch --listFiles false --listEmittedFiles false",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "type-check": "bunx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "valibot": "^1.2.0"
  },
  "peerDependencies": {
    "@donotdev/core": "^0.1.43",
    "@donotdev/functions": "^0.1.43",
    "express": ">=4",
    "fastify": ">=4",
    "hono": ">=4",
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "@donotdev/functions": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@donotdev/core": "workspace:*",
    "@donotdev/functions": "workspace:*",
    "express": "^5.2.1",
    "fastify": "^5.1.0",
    "hono": "^4.12.9",
    "next": "^16.2.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/donotdev/dndev.git"
  },
  "keywords": [
    "donotdev",
    "dndev",
    "rest",
    "crud",
    "adapter",
    "react",
    "typescript"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}